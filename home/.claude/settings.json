{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "200000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Skill(commit)",
      "Skill(commit-commands:*)",
      "Skill(creating-hooks)",
      "Skill(difit-here)",
      "Skill(generating-skills-from-logs)",
      "Skill(managing-frontend-knowledge)",
      "Skill(review-pr)",
      "Skill(review-and-improve)",
      "WebSearch",
      "mcp__chrome-devtools__*",
      "mcp__deepwiki__*",
      "mcp__drawio__*",
      "mcp__plugin_context7_context7__*"
    ],
    "deny": [
      "Bash(do:*)",
      "Bash(for:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(until:*)",
      "Bash(while:*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*secret*)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(~/.ssh/*)",
      "Write(**/*secret*)",
      "Write(**/.env*)"
    ],
    "ask": [
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(wget:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/dotfiles/scripts/development/validate-command.ts"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/protect-sensitive.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/protect-sensitive.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/dotfiles/scripts/development/claude-notify.ts",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "セッション終了です。このセッションで実質的な作業（コード変更、設計議論、調査など）がなかった場合はサマリー保存をスキップしてください。\n\n作業があった場合は以下の手順でサマリーを保存:\n1. .claude/sessions/ ディレクトリがなければ作成\n2. `git diff --name-only` で変更ファイル一覧を取得\n3. 以下の形式で .claude/sessions/YYYY-MM-DD-HHmm.md に保存（現在時刻を使用）\n\nフォーマット:\n```\n# Session Summary - YYYY-MM-DD HH:mm\n\n## やったこと\n（このセッションで取り組んだタスクの要約、2-5行）\n\n## 変更ファイル\n（git diff --name-only の結果をリスト化。変更がなければ「なし」）\n\n## 決定事項\n（セッション中に下した設計・方針の判断。なければ「なし」）\n\n## 未解決事項\n（残タスク、保留中の問題、次セッションで対応すべきこと。なければ「なし」）\n```\n\n簡潔に、次セッションの自分が読んで即座にコンテキスト復元できる粒度で書いてください。ファイル保存後は「セッションサマリーを保存しました」と一言だけ報告してください。"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|auth_success|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/dotfiles/scripts/development/claude-notify.ts",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/check-marketplace-health.ts",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.ts"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "designer-skills": {
      "source": {
        "source": "github",
        "repo": "Owl-Listener/designer-skills"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./plans",
  "skipAutoPermissionPrompt": true
}
