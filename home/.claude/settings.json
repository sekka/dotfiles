{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(alias:*)",
      "Bash(basename:*)",
      "Bash(bats:*)",
      "Bash(brew:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(cat:*)",
      "Bash(claude:*)",
      "Bash(codesign:*)",
      "Bash(codex:*)",
      "Bash(command -v:*)",
      "Bash(command brew bundle)",
      "Bash(defaults read:*)",
      "Bash(difit-here.sh)",
      "Bash(dprint fmt:*)",
      "Bash(echo:*)",
      "Bash(env)",
      "Bash(eza:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(fuser:*)",
      "Bash(fzf:*)",
      "Bash(gemini:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(gpg:*)",
      "Bash(gpgconf:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(keifu:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(mdfind:*)",
      "Bash(mise:*)",
      "Bash(mkdir:*)",
      "Bash(mlx_audio.tts.generate:*)",
      "Bash(navi *)",
      "Bash(npx tsc:*)",
      "Bash(oxlint:*)",
      "Bash(printenv:*)",
      "Bash(ps:*)",
      "Bash(pstree:*)",
      "Bash(rg:*)",
      "Bash(rtk:*)",
      "Bash(shellcheck:*)",
      "Bash(tcmux:*)",
      "Bash(test:*)",
      "Bash(timeout:*)",
      "Bash(tmux:*)",
      "Bash(tree:*)",
      "Bash(tts-clone:*)",
      "Bash(tts:*)",
      "Bash(unset:*)",
      "Bash(uv:*)",
      "Bash(wait:*)",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "Bash(yazi:*)",
      "Bash(zoxide:*)",
      "Skill(commit)",
      "Skill(commit-commands:*)",
      "Skill(difit-here)",
      "Skill(generating-skills-from-logs)",
      "Skill(managing-frontend-knowledge)",
      "Skill(review-pr)",
      "Skill(reviewing-with-claude)",
      "WebSearch",
      "mcp__chrome-devtools__*",
      "mcp__deepwiki__*",
      "mcp__drawio__*",
      "mcp__plugin_context7_context7__*"
    ],
    "deny": [
      "Bash(do:*)",
      "Bash(for:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(until:*)",
      "Bash(while:*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*secret*)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(~/.ssh/*)",
      "Write(**/*secret*)",
      "Write(**/.env*)"
    ],
    "ask": [
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(wget:*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/dotfiles/scripts/development/validate-command.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/protect-sensitive.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/protect-sensitive.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kei/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/dotfiles/scripts/development/claude-notify.ts"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|auth_success|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/dotfiles/scripts/development/claude-notify.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/check-marketplace-health.ts"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.ts"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "firebase@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "vercel@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": false,
    "code-simplifier@claude-plugins-official": false,
    "ask-claude@hiropon-plugins": false,
    "ask-codex@hiropon-plugins": false,
    "ask-gemini@hiropon-plugins": false,
    "peer@hiropon-plugins": false,
    "mgrep@Mixedbread-Grep": false,
    "playground@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "design-research@designer-skills": true,
    "design-systems@designer-skills": true,
    "ux-strategy@designer-skills": true,
    "ui-design@designer-skills": true,
    "interaction-design@designer-skills": true,
    "prototyping-testing@designer-skills": true,
    "design-ops@designer-skills": true,
    "designer-toolkit@designer-skills": true,
    "code-review@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "designer-skills": {
      "source": {
        "source": "github",
        "repo": "Owl-Listener/designer-skills"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./plans",
  "skipAutoPermissionPrompt": true
}
