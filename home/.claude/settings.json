{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "200000",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "permissions": {
    "allow": [
      "Bash(agent-browser *)",
      "Bash(brew *)",
      "Bash(bun scripts/development/lint-format.ts)",
      "Bash(bun test:*)",
      "Bash(cairosvg --version)",
      "Bash(cat)",
      "Bash(claude *)",
      "Bash(codex:*)",
      "Bash(darwin-rebuild *)",
      "Bash(dprint *)",
      "Bash(gh repo:*)",
      "Bash(gh skill *)",
      "Bash(mise *)",
      "Bash(mkdir:*)",
      "Bash(nix search:*)",
      "Bash(npx *)",
      "Bash(qmd *)",
      "Bash(rsvg-convert --version)",
      "Bash(rtk *)",
      "Bash(shellcheck:*)",
      "Bash(tmux list-panes *)",
      "Bash(wait)",
      "Bash(wrangler *)",
      "Skill(codex:rescue)",
      "Skill(commit-commands:*)",
      "Skill(creating-hooks)",
      "Skill(difit-here)",
      "Skill(review-pr)",
      "Skill(schedule)",
      "Skill(user-dev-commit)",
      "Skill(user-dev-review)",
      "Skill(user-dotfiles-tool-config)",
      "Skill(user-fe-knowledge)",
      "Skill(user-harness-gen-skills)",
      "Skill(user-harness-ship)",
      "Skill(user-research-eval-ref)",
      "Skill(user-research-x-posts)",
      "WebFetch(domain:agent-browser.io)",
      "WebFetch(domain:aimanavo.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:azukiazusa.dev)",
      "WebFetch(domain:bun.com)",
      "WebFetch(domain:cli.github.com)",
      "WebFetch(domain:coliss.com)",
      "WebFetch(domain:dev.classmethod.jp)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.coderabbit.ai)",
      "WebFetch(domain:formulae.brew.sh)",
      "WebFetch(domain:gihyo.jp)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:ics.media)",
      "WebFetch(domain:liginc.co.jp)",
      "WebFetch(domain:loftwork.com)",
      "WebFetch(domain:martinfowler.com)",
      "WebFetch(domain:note.com)",
      "WebFetch(domain:photoshopvip.net)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:qiita.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:search.nixos.org)",
      "WebFetch(domain:togetter.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:www.celebrain.com)",
      "WebFetch(domain:www.figma.com)",
      "WebFetch(domain:www.hrpro.co.jp)",
      "WebFetch(domain:x.com)",
      "WebFetch(domain:zenn.dev)",
      "WebSearch",
      "Write",
      "mcp__deepwiki__*",
      "mcp__drawio__*",
      "mcp__playwright__*",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_playwright_playwright__*",
      "mcp__sem__*"
    ],
    "deny": [
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*secret*)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(~/.ssh/*)",
      "Write(**/*secret*)",
      "Write(**/.env*)"
    ],
    "ask": [
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(gh extension *)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "Bash(open *)",
      "Bash(rm:*)",
      "Bash(wget:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validate-command.ts"
          },
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/auth-guard.ts"
          },
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/rtk-rewrite.ts"
          }
        ]
      },
      {
        "matcher": "WebFetch|mcp__plugin_context7_context7__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/security-scan.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/protect-sensitive.sh"
          },
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/read-before-edit-hook.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/delegation-guard.ts"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/protect-sensitive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/post-format.ts",
            "async": true
          },
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/edit-counter-hook.ts"
          },
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/mermaid-validate.ts",
            "async": true
          },
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/md-preview.ts",
            "async": true
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/track-read-hook.ts"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/error-loop-hook.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/circuit-breaker.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/claude-notify.ts",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/commit-reminder.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/language-check.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/queue-stop-guard.ts"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/claude-notify.ts",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|auth_success|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/claude-notify.ts",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/check-marketplace-health.ts",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/check-memory-health.ts",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/orphan-reaper.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/cleanup-agent-browser.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/git-context.ts"
          },
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/language-reminder.ts"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/save-progress.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.ts",
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "codex@openai-codex": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": false,
    "coderabbit@claude-plugins-official": true,
    "figma@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "visual-explainer@visual-explainer-marketplace": true,
    "cloudflare@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "designer-skills": {
      "source": {
        "source": "github",
        "repo": "Owl-Listener/designer-skills"
      }
    },
    "hiropon-plugins": {
      "source": {
        "source": "github",
        "repo": "hiroro-work/claude-plugins"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "visual-explainer-marketplace": {
      "source": {
        "source": "github",
        "repo": "nicobailon/visual-explainer"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "advisorModel": "opus",
  "plansDirectory": "./plans",
  "showThinkingSummaries": true,
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
