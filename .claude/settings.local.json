{
  "permissions": {
    "allow": [
      "Bash(nix search:*)",
      "Bash(darwin-rebuild switch:*)",
      "Bash(darwin-rebuild build:*)",
      "WebFetch(domain:github.com)",
      "Bash(shellcheck:*)",
      "WebFetch(domain:x.com)",
      "mcp__playwright__*",
      "WebFetch(domain:playwright.dev)",
      "Bash(claude mcp:*)",
      "Bash(brew deps:*)",
      "Bash(brew list:*)",
      "WebFetch(domain:search.nixos.org)",
      "Skill(schedule)",
      "WebFetch(domain:agent-browser.io)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:mynixos.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(agent-browser navigate:*)",
      "WebFetch(domain:zenn.dev)",
      "WebFetch(domain:qiita.com)"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
    "chrome-devtools",
    "context7",
    "deepwiki",
    "filesystem",
    "markitdown",
    "sequential-thinking"
  ],
  "disabledMcpjsonServers": [
    "better-icons",
    "brave-search",
    "drawio"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/dotfiles/scripts/hooks/auto-lint-hook.ts"
          }
        ]
      }
    ]
  }
}
