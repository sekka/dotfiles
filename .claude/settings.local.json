{
  "permissions": {
    "allow": [
      "Bash(nix search:*)",
      "Bash(darwin-rebuild switch:*)",
      "Bash(darwin-rebuild build:*)",
      "WebFetch(domain:github.com)",
      "Bash(shellcheck:*)"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
    "chrome-devtools",
    "context7",
    "deepwiki",
    "filesystem",
    "markitdown",
    "sequential-thinking"
  ],
  "disabledMcpjsonServers": [
    "better-icons",
    "brave-search",
    "drawio"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/dotfiles/scripts/development/lint-format.ts --mode=fix --file=$FILE_PATH"
          }
        ]
      }
    ]
  }
}
